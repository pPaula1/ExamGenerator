{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "exam/exam.schema.json",
  "title": "Exam",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "tasks"],
  "properties": {
    "$schema": { "type": "string" },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]{2,64}$"
    },
    "name": { "type": "string", "minLength": 1, "maxLength": 200 },
    "subtitle": { "type": "string" },
    "school_info_ref": {
      "type": "string",
      "description": "Path or identifier to a school_info.json document."
    },
    "header": {
      "oneOf": [
        { "$ref": "../header/header.schema.json" },
        { "type": "string" }
      ],
      "description": "Inline header config or reference to header JSON file."
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "type": "string",
            "minLength": 1,
            "description": "Path to task JSON file."
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["path"],
            "properties": {
              "path": { "type": "string", "minLength": 1 },
              "task_id": { "type": "string" },
              "points_override": { "type": "number", "minimum": 0 },
              "page_break_before": { "type": "boolean", "default": false }
            }
          }
        ]
      }
    },
    "render": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "title_page": { "type": "boolean", "default": false },
        "page_break_between_tasks": { "type": "boolean", "default": false },
        "show_total_points": { "type": "boolean", "default": true }
      }
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "school_year": { "type": "string" },
        "grade_level": { "type": "string" },
        "exam_date": { "type": "string" },
        "notes": { "type": "string" }
      }
    },
    "version": { "type": "string", "default": "1.0" }
  }
}
