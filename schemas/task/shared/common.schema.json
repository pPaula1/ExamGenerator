{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "shared/common.schema.json",
  "title": "Common",
  "$defs": {
    "taskId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]{2,64}$"
    },
    "partId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]{0,64}$"
    },
    "variantId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]{1,64}$"
    },
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "nonNegativeNumber": {
      "type": "number",
      "minimum": 0
    }
  }
}
