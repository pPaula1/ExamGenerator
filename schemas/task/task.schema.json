{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "task.schema.json",
  "title": "Task",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "statement",
    "points"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "id": { "$ref": "./shared/common.schema.json#/$defs/taskId" },
    "name": { "type": "string", "minLength": 1, "maxLength": 200 },
    "statement": { "type": "string", "minLength": 1 },
    "points": { "$ref": "./shared/common.schema.json#/$defs/nonNegativeNumber" },
    "subject": { "type": "string" },
    "topic": { "type": "string" },
    "tags": {
      "type": "array",
      "items": { "$ref": "./shared/common.schema.json#/$defs/nonEmptyString" },
      "default": []
    },
    "render": { "$ref": "./core/render.schema.json" },
    "assets": {
      "type": "array",
      "items": { "$ref": "./core/asset.schema.json" },
      "default": []
    },
    "parts": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id"],
        "properties": {
          "id": { "$ref": "./shared/common.schema.json#/$defs/partId" },
          "type": {
            "type": "string",
            "enum": ["text", "checkbox_group", "matching", "table"],
            "default": "text",
            "description": "Use checkbox_group for Kreuzaufgaben, matching for Zuordnungsaufgaben and table for tabular tasks."
          },
          "text": { "type": "string", "minLength": 1 },
          "checkbox_items": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "./core/checkbox_item.schema.json" },
            "description": "Checkbox lines shown as: free box + statement text."
          },
          "matching": {
            "$ref": "./core/matching_group.schema.json",
            "description": "Matching task with left_items and right_items."
          },
          "table": {
            "$ref": "./core/table.schema.json",
            "description": "Table task content with headers, rows and optional layout hints."
          },
          "textboxes": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "./core/textbox.schema.json" },
            "description": "Additional blocks below part text. Each block can be text or formula."
          },
          "points": { "$ref": "./shared/common.schema.json#/$defs/nonNegativeNumber" },
          "assets": {
            "type": "array",
            "items": { "$ref": "./core/asset.schema.json" },
            "default": []
          },
          "workspace": {
            "type": "array",
            "items": { "$ref": "./core/workspace.schema.json" },
            "default": []
          }
        },
        "anyOf": [
          { "required": ["text"] },
          { "required": ["checkbox_items"] },
          { "required": ["matching"] },
          { "required": ["table"] },
          { "required": ["textboxes"] }
        ],
        "allOf": [
          {
            "if": {
              "required": ["type"],
              "properties": {
                "type": { "const": "text" }
              }
            },
            "then": { "required": ["text"] }
          },
          {
            "if": {
              "required": ["type"],
              "properties": {
                "type": { "const": "checkbox_group" }
              }
            },
            "then": { "required": ["checkbox_items"] }
          },
          {
            "if": {
              "required": ["type"],
              "properties": {
                "type": { "const": "matching" }
              }
            },
            "then": { "required": ["matching"] }
          },
          {
            "if": {
              "required": ["type"],
              "properties": {
                "type": { "const": "table" }
              }
            },
            "then": { "required": ["table"] }
          }
        ]
      }
    },
    "workspace": {
      "type": "array",
      "items": { "$ref": "./core/workspace.schema.json" },
      "default": [
        { "type": "lines", "lines": 4 }
      ]
    },
    "template": { "$ref": "./template/template.schema.json" },
    "instances": {
      "type": "array",
      "items": { "$ref": "./template/instance.schema.json" },
      "default": []
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ref": { "type": "string" },
        "notes": { "type": "string" }
      }
    },
    "version": { "type": "string", "default": "1.0" }
  }
}
